{
  "manifest_version": 3,
  "name": "PNCP-TO-EXCEL",
  "version": "1.0",
  "description": "Extrai dados do PNCP e converte para planilha do Excel.",
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "content_scripts": [
    {
      "matches": ["*://pncp.gov.br/*", "*://*.pncp.gov.br/*"],
      "js": [
        "libs/xlsx.full.min.js", 
        "scripts/content.js"
      ],
      "css": ["styles/style.css"]
    }
  ]
}